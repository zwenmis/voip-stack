<include>
  <settings>
    <param name="tls-version" value="${TLS_VERSION}"/>
    <param name="tls-cipher-suite" value="${TLS_CIPHERS}"/>
  </settings>

  <profiles>
    <profile name="internal">
      <settings>
        <param name="sip-port" value="5060"/>
        <param name="sip-ip" value="0.0.0.0"/>
        <param name="tls-port" value="5061"/>
        <param name="tls-ip" value="0.0.0.0"/>
        <param name="ws-port" value="5066"/>
        <param name="wss-port" value="7443"/>
        <param name="rtp-ip" value="${EXTERNAL_IP}"/>
        <param name="sip-ip" value="${EXTERNAL_IP}"/>
        <param name="ext-rtp-ip" value="${EXTERNAL_IP}"/>
        <param name="ext-sip-ip" value="${EXTERNAL_IP}"/>
        <param name="rtp-port-range-start" value="16384"/>
        <param name="rtp-port-range-end" value="32768"/>
        <param name="auth-calls" value="false"/>
        <param name="auth-all-packets" value="false"/>
        <param name="inbound-bypass-media" value="true"/>
        <param name="inbound-proxy-media" value="true"/>
        <param name="media-option" value="SRTP"/>
        <param name="apply-inbound-acl" value="localnet.auto"/>
        <param name="apply-register-acl" value="localnet.auto"/>
        <param name="challenge-realm" value="voip.local"/>
        <param name="ndlb-allow-bad-iananame" value="true"/>
        <param name="ndlb-force-rport" value="safe"/>
        <param name="nonce-ttl" value="60"/>
        <param name="verbose-presence" value="false"/>
        <param name="tls-version" value="${TLS_VERSION}"/>
        <param name="tls-cipher-suite" value="${TLS_CIPHERS}"/>
        <param name="ws-binding" value=":5066"/>
        <param name="wss-binding" value=":7443"/>
        <param name="rtp-timeout-sec" value="300"/>
        <param name="rtp-hold-timeout-sec" value="1800"/>
      </settings>
    </profile>
  </profiles>
</include>